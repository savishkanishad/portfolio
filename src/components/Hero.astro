---
---
<section class="relative py-20 min-h-[90vh] flex flex-col items-start justify-center max-w-4xl overflow-hidden">
  <!-- Mesh Gradient Background -->
  <div class="absolute -top-[10%] -left-[10%] w-[120%] h-[120%] overflow-hidden pointer-events-none -z-20 opacity-40">
    <div class="absolute top-[20%] left-[30%] w-[40%] h-[40%] bg-blue-600/30 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute top-[40%] right-[20%] w-[35%] h-[35%] bg-purple-600/20 rounded-full blur-[100px] animate-bounce" style="animation-duration: 8s"></div>
    <div class="absolute bottom-[10%] left-[40%] w-[30%] h-[30%] bg-cyan-600/20 rounded-full blur-[90px] animate-pulse" style="animation-duration: 12s"></div>
  </div>

  <!-- Glowing background effect -->
  <div class="absolute -top-20 -left-20 w-64 h-64 bg-blue-600/20 rounded-full blur-[120px] -z-10"></div>

  <div class="animate-fade-up">
    <span class="text-blue-500 font-mono mb-4 block tracking-widest uppercase text-sm">Hi, my name is</span>
    <h1 class="text-6xl md:text-8xl font-black text-white leading-tight tracking-tighter">
      Savishka <span class="text-gradient">Nishad.</span>
    </h1>
  </div>

  <div class="animate-fade-up delay-100">
    <h2 class="text-4xl md:text-6xl font-bold text-slate-400 mt-2">
      I build secure, AI-driven solutions.
    </h2>
  </div>

  <div class="animate-fade-up delay-200">
    <p class="mt-8 text-xl text-slate-400 max-w-2xl leading-relaxed">
      I’m a Software Development student specializing in <span class="text-white font-medium underline decoration-blue-500/30 decoration-2 underline-offset-4">backend architecture</span> and <span class="text-white font-medium underline decoration-purple-500/30 decoration-2 underline-offset-4">cybersecurity</span>. Currently, I’m focused on building <span class="text-blue-400 font-semibold italic">NeuroGuard</span>, an AI system for driver safety.
    </p>
  </div>

  <div class="mt-12 flex flex-wrap gap-6 animate-fade-up delay-300">
    <a href="#projects" class="px-10 py-5 bg-blue-600 text-white font-black rounded-2xl hover:bg-blue-700 hover:shadow-[0_0_25px_rgba(37,99,235,0.4)] transition-all transform hover:-translate-y-1">
      View My Work
    </a>
    <a href="/cv.pdf" class="px-10 py-5 border border-slate-700 text-white font-black rounded-2xl hover:bg-slate-800/50 hover:border-slate-500 transition-all transform hover:-translate-y-1 group">
      Download CV <span class="inline-block transform group-hover:translate-y-1 transition-transform">↓</span>
    </a>
  </div>
</section>